TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgresql://user:password@localhost:5432/opentrade
# LLM provider: openrouter (default) | openai | anthropic | gemini | ollama | lmstudio
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-3-5-sonnet

# OpenRouter (used when LLM_PROVIDER=openrouter)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1

# Direct cloud providers — set only the key for your chosen provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Local providers
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234/v1
OPERATOR_USER_ID=
MASTER_PASSWORD=

# Exchange API keys (set via: npm run cli connect <exchange>)
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=

# Paper trading mode (no real orders, simulated $10k USDT balance)
# PAPER_TRADING=true
